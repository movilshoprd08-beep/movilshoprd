      { id:45, nombre:"Motorola Edge 60 Fusion",storage:"256GB+24GB",precio:16300, extra:"" },
      { id:46, nombre:"Motorola Edge 60 Pro 5G",storage:"512GB+36GB",precio:27300, extra:"" },
      { id:47, nombre:"Motorola Edge 70 Fusion",storage:"256GB+8GB", precio:24400, extra:"" },
    ]},
    { nombre: "Xiaomi", productos: [
      { id:50, nombre:"Redmi A7 Pro",      storage:"64GB+4GB",   precio:6100,  extra:"" },
      { id:51, nombre:"Redmi 15C",         storage:"256GB+4GB",  precio:7800,  extra:"" },
      { id:52, nombre:"Redmi 15",          storage:"256GB+8GB",  precio:10600, extra:"" },
      { id:53, nombre:"Note 15 Pro 5G",    storage:"256GB+8GB",  precio:16950, extra:"" },
      { id:54, nombre:"Poco F8 Pro",       storage:"512GB+12GB", precio:35900, extra:"" },
    ]},
    { nombre: "Oukitel", productos: [
      { id:15, nombre:"Oukitel C1",        storage:"128GB+4GB",  precio:6000,  extra:"" },
      { id:17, nombre:"Oukitel C26",       storage:"128GB+4GB",  precio:6800,  extra:"" },
      { id:60, nombre:"Oukitel C61",       storage:"128GB+16GB", precio:6900,  extra:"" },
      { id:61, nombre:"Oukitel C61 GT",    storage:"128GB+16GB", precio:7000,  extra:"" },
      { id:81, nombre:"Oukitel C61 Pro",   storage:"256GB+24GB", precio:8100,  extra:"" },
      { id:16, nombre:"Oukitel C60 Pro",   storage:"256GB+8GB",  precio:9300,  extra:"" },
      { id:65, nombre:"Oukitel P1 Pro",    storage:"256GB+4GB",  precio:10000, extra:"" },
      { id:66, nombre:"Oukitel P1 Pro",    storage:"512GB+8GB",  precio:11600, extra:"" },
      { id:69, nombre:"Oukitel G5",        storage:"64GB+4GB",   precio:6850,  extra:"" },
      { id:70, nombre:"Oukitel G6",        storage:"64GB+4GB",   precio:8150,  extra:"" },
      { id:71, nombre:"Oukitel G7",        storage:"128GB+4GB",  precio:9650,  extra:"" },
      { id:72, nombre:"Oukitel G7",        storage:"256GB+8GB",  precio:11000, extra:"" },
      { id:73, nombre:"Oukitel WP28E",     storage:"64GB+16GB",  precio:8050,  extra:"" },
      { id:74, nombre:"Oukitel WP53 Pro",  storage:"256GB+8GB",  precio:11000, extra:"" },
      { id:75, nombre:"Oukitel WP39 5G",   storage:"256GB+24GB", precio:14100, extra:"" },
      { id:76, nombre:"Oukitel WP55 S",    storage:"256GB+24GB", precio:14300, extra:"" },
      { id:79, nombre:"Oukitel WP60",      storage:"256GB+8GB",  precio:16200, extra:"" },
      { id:82, nombre:"Oukitel WP56",      storage:"256GB+32GB", precio:16200, extra:"" },
      { id:83, nombre:"Oukitel WP19 Pro",  storage:"256GB+24GB", precio:16200, extra:"" },
      { id:77, nombre:"Oukitel WP55 Pro",  storage:"512GB+16GB", precio:18100, extra:"" },
      { id:78, nombre:"Oukitel WP56",      storage:"512GB+12GB", precio:19600, extra:"" },
      { id:84, nombre:"Oukitel WP60",      storage:"512GB+16GB", precio:19900, extra:"" },
      { id:80, nombre:"Oukitel WP66",      storage:"512GB+12GB", precio:20200, extra:"" },
      { id:85, nombre:"Oukitel WP61 Plus", storage:"512GB+12GB", precio:23900, extra:"" },
      { id:86, nombre:"Oukitel WP200 Pro", storage:"1TB+24GB",   precio:32200, extra:"" },
    ]},
    { nombre: "Honor", productos: [
      { id:90, nombre:"Honor Choice Watch 2I", storage:"",          precio:2400,  extra:"" },
      { id:91, nombre:"Honor Play 10",         storage:"64GB+6GB",  precio:5000,  extra:"" },
      { id:92, nombre:"Honor X8C",             storage:"256GB+8GB", precio:11600, extra:"" },
      { id:93, nombre:"Honor X8C",             storage:"512GB+8GB", precio:13100, extra:"" },
      { id:94, nombre:"Honor 400 Smart",       storage:"256GB+8GB", precio:13700, extra:"" },
      { id:95, nombre:"Honor Magic 8 Lite",    storage:"256GB+8GB", precio:20700, extra:"" },
    ]},
    { nombre: "M-Horse", productos: [
      { id:100, nombre:"M-Horse M17 Pro",       storage:"32GB+3GB",   precio:4200, extra:"" },
      { id:101, nombre:"M-Horse S26+",          storage:"32GB+4GB",   precio:4200, extra:"" },
      { id:102, nombre:"M-Horse S25 Pro+",      storage:"64GB+6GB",   precio:5000, extra:"" },
      { id:103, nombre:"M-Horse M17 Pro",       storage:"64GB+4GB",   precio:5500, extra:"" },
      { id:104, nombre:"M-Horse S26 Ultra Max", storage:"64GB+8GB",   precio:5500, extra:"" },
      { id:105, nombre:"M-Horse Note 14 Pro+ Ultra", storage:"128GB+8GB", precio:6000, extra:"" },
      { id:106, nombre:"M-Horse M17 Pro Max",   storage:"128GB+8GB",  precio:6350, extra:"🎧 AirPods incluidos" },
      { id:107, nombre:"M-Horse S26 Ultra Max+",storage:"128GB+12GB", precio:6350, extra:"" },
    ]},
    { nombre: "ZTE", productos: [
      { id:110, nombre:"ZTE A35E",  storage:"64GB+6GB",       precio:5000, extra:"" },
      { id:111, nombre:"ZTE A54",   storage:"64GB+4GB (2SIM)", precio:5100, extra:"" },
      { id:112, nombre:"ZTE A75",   storage:"64GB+10GB",      precio:7200, extra:"" },
    ]},
    { nombre: "Apple", productos: [
      { id:1,  nombre:"iPhone 13",         storage:"256GB", precio:18500, extra:"" },
      { id:2,  nombre:"iPhone 13 Pro",     storage:"128GB", precio:20800, extra:"" },
      { id:3,  nombre:"iPhone 14",         storage:"128GB", precio:16600, extra:"" },
      { id:4,  nombre:"iPhone 14 Plus",    storage:"128GB", precio:19800, extra:"" },
      { id:5,  nombre:"iPhone 14 Pro Max", storage:"128GB", precio:30500, extra:"" },
      { id:6,  nombre:"iPhone 12 Pro",     storage:"256GB", precio:16800, extra:"" },
      { id:7,  nombre:"iPhone 15 Pro Max", storage:"256GB", precio:37500, extra:"" },
    ]},
  ];

  const cantidades = {};
  marcas.forEach(m => m.productos.forEach(p => cantidades[p.id] = 0));
  const fmt = n => "RD$" + n.toLocaleString("es-DO");

  let filtroActivo = "Todos";

  function renderFiltros() {
    const filtros = document.getElementById("filtros");
    const opciones = ["Todos", ...marcas.map(m => m.nombre)];
    filtros.innerHTML = opciones.map(f => `
      <button class="filtro-btn ${f === filtroActivo ? 'active' : ''}" onclick="setFiltro('${f}')">${f}</button>
    `).join("");
  }

  function setFiltro(marca) {
    filtroActivo = marca;
    renderFiltros();
    renderCatalog();
  }

  function renderCatalog() {
    const marcasFiltradas = filtroActivo === "Todos" ? marcas : marcas.filter(m => m.nombre === filtroActivo);
    document.getElementById("catalogWrapper").innerHTML = marcasFiltradas.map(m => `
      <div class="brand-section">
        <div class="brand-header">
          <span class="brand-name">${m.nombre}</span>
          <span class="brand-count">${m.productos.length} equipo${m.productos.length>1?'s':''}</span>
          <div class="brand-divider"></div>
        </div>
        <div class="brand-grid">
          ${m.productos.map(p => `
            <div class="card ${cantidades[p.id]>0?'selected':''}" id="card-${p.id}">
              <div class="phone-icon">📱</div>
              <div class="card-name">${p.nombre}</div>
              <div class="card-storage">${p.storage}</div>
              ${p.extra?`<div class="extra-badge">${p.extra}</div>`:''}
              <div class="card-price">${fmt(p.precio)}</div>
              <div class="qty-controls">
                <button class="qty-btn" onclick="cambiar(${p.id},-1)">−</button>
                <span class="qty-num" id="qty-${p.id}">${cantidades[p.id]}</span>
                <button class="qty-btn" onclick="cambiar(${p.id},1)">+</button>
              </div>
            </div>
          `).join('')}
        </div>
      </div>
    `).join('');
  }

  function cambiar(id, delta) {
    cantidades[id] = Math.max(0, cantidades[id] + delta);
    document.getElementById("qty-"+id).textContent = cantidades[id];
    document.getElementById("card-"+id).classList.toggle("selected", cantidades[id]>0);
    actualizar();
  }

  function actualizar() {
    let total=0, items=0;
    marcas.forEach(m => m.productos.forEach(p => { total+=p.precio*cantidades[p.id]; items+=cantidades[p.id]; }));
    document.getElementById("totalDisplay").textContent = fmt(total);
    document.getElementById("cartCount").textContent = items;
    document.getElementById("sendBtn").disabled = items===0;
    document.getElementById("emptyHint").style.display = items===0?"block":"none";
  }

  function enviarPedido() {
    let total=0, lineas=[];
    marcas.forEach(m => {
      const sel = m.productos.filter(p=>cantidades[p.id]>0);
      if(sel.length){ 
        lineas.push(`\n*CELULARES ${m.nombre.toUpperCase()}*`);
        sel.forEach(p=>{ const s=p.precio*cantidades[p.id]; total+=s; lineas.push(`• ${p.nombre.toUpperCase()} ${p.storage} (${cantidades[p.id]}x) - ${fmt(s)}`); });
      }
    });
    if(!lineas.length) return;
    window.open(`https://wa.me/${WHATSAPP}?text=${encodeURIComponent(`*LISTADO DEL DIA*\n`+lineas.join("\n")+`\n\n*Total: ${fmt(total)}*`)}`, "_blank");
  }

  renderFiltros(); renderCatalog(); actualizar();
</script>
</body>
</html>
