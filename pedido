<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Catálogo – Móvil Shop RD</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0a0d14; --surface: #111827; --card: #1a2235;
      --border: #1e3a5f; --accent: #1d4ed8; --accent2: #3b82f6;
      --gold: #f59e0b; --text: #f0f6ff; --muted: #7a90b0; --green: #22c55e;
    }
    html { background: #0a0d14; }
    body { background: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; min-height: 100vh; }

    header {
      background: var(--surface); border-bottom: 1px solid var(--border);
      padding: 10px 16px; position: sticky; top: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
    }
    .logo-text { font-size: 16px; font-weight: 900; letter-spacing: -0.5px; color: #fff; }
    .logo-text span { color: var(--accent2); }
    .cart-btn {
      background: var(--accent); color: white; border: none; border-radius: 10px;
      padding: 8px 14px; font-size: 13px; font-weight: 600; cursor: pointer;
      display: flex; align-items: center; gap: 6px;
    }
    .cart-count {
      background: var(--gold); color: #000; border-radius: 50%;
      width: 18px; height: 18px; font-size: 11px; font-weight: 700;
      display: flex; align-items: center; justify-content: center;
    }

    .hero { padding: 28px 20px 16px; text-align: center; background: var(--bg); }
    .hero-tag {
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(29,78,216,0.15); border: 1px solid rgba(59,130,246,0.3);
      color: var(--accent2); font-size: 12px; font-weight: 600;
      padding: 4px 12px; border-radius: 20px; margin-bottom: 12px;
      letter-spacing: 0.5px; text-transform: uppercase;
    }
    .hero h1 { font-size: clamp(24px,6vw,38px); font-weight: 900; letter-spacing: -1px; line-height: 1.1; margin-bottom: 8px; }
    .hero h1 span { background: linear-gradient(90deg,var(--accent2),var(--gold)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
    .hero p { color: var(--muted); font-size: 14px; margin-bottom: 6px; }
    .stock-badge { display:inline-flex; align-items:center; gap:5px; color:var(--green); font-size:12px; font-weight:600; }
    .dot { width:7px; height:7px; background:var(--green); border-radius:50%; animation:pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

    .filtros-wrapper { position: sticky; top: 65px; z-index: 90; background: var(--bg); padding: 10px 0 6px; border-bottom: 1px solid var(--border); }
    .filtros { display: flex; gap: 8px; padding: 0 16px; overflow-x: auto; scrollbar-width: none; }
    .filtros::-webkit-scrollbar { display: none; }
    .filtro-btn {
      background: var(--card); border: 1px solid var(--border); color: var(--muted);
      border-radius: 20px; padding: 6px 14px; font-size: 12px; font-weight: 600;
      cursor: pointer; white-space: nowrap; transition: all 0.2s; flex-shrink: 0;
    }
    .filtro-btn:hover { border-color: var(--accent2); color: var(--text); }
    .filtro-btn.active { background: var(--accent); border-color: var(--accent); color: white; }

    .catalog-wrapper { padding: 16px 16px 130px; max-width: 720px; margin: 0 auto; background: var(--bg); }
    .brand-section { margin-bottom: 28px; background: var(--bg); }
    .brand-header { display:flex; align-items:center; gap:10px; margin-bottom:12px; background: var(--bg); }
    .brand-name { font-size:18px; font-weight:900; color:#ffffff; background: var(--accent); padding:3px 14px; border-radius:8px; }
    .brand-count { font-size:11px; font-weight:600; color:var(--muted); background:rgba(59,130,246,0.1); border:1px solid rgba(59,130,246,0.2); padding:2px 8px; border-radius:20px; }
    .brand-divider { flex:1; height:1px; background:var(--border); }
    .brand-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(155px,1fr)); gap:10px; }

    .card { background:var(--card); border:1px solid var(--border); border-radius:16px; padding:14px 12px; display:flex; flex-direction:column; gap:9px; transition:border-color 0.2s,transform 0.2s; }
    .card:hover { border-color:var(--accent2); transform:translateY(-2px); }
    .card.selected { border-color:var(--accent2); background:rgba(29,78,216,0.12); }
    .phone-icon { font-size:28px; text-align:center; }
    .card-name { font-size:13px; font-weight:700; color:var(--text); line-height:1.3; }
    .card-storage { font-size:11px; color:var(--accent2); font-weight:600; background:rgba(59,130,246,0.12); display:inline-block; padding:2px 8px; border-radius:20px; }
    .extra-badge { font-size:11px; font-weight:700; color:var(--gold); background:rgba(245,158,11,0.12); border:1px solid rgba(245,158,11,0.3); border-radius:20px; padding:3px 9px; display:inline-block; }
    .card-price { font-size:15px; font-weight:900; color:var(--gold); }
    .qty-controls { display:flex; align-items:center; justify-content:space-between; background:var(--bg); border-radius:10px; padding:4px; }
    .qty-btn { background:var(--accent); color:white; border:none; width:28px; height:28px; border-radius:7px; font-size:16px; font-weight:700; cursor:pointer; display:flex; align-items:center; justify-content:center; }
    .qty-btn:hover { background:var(--accent2); }
    .qty-num { font-size:15px; font-weight:700; color:var(--text); min-width:24px; text-align:center; }

    .footer-bar { position:fixed; bottom:0; left:0; right:0; background:var(--surface); border-top:1px solid var(--border); padding:14px 20px; display:flex; align-items:center; justify-content:space-between; gap:12px; z-index:200; }
    .footer-info { display:flex; flex-direction:column; gap:2px; }
    .footer-label { font-size:11px; color:var(--muted); }
    .footer-total { font-size:18px; font-weight:900; color:var(--gold); }
    .empty-hint { color:var(--muted); font-size:12px; }
    .send-btn { background:linear-gradient(135deg,#25d366,#128c7e); color:white; border:none; border-radius:12px; padding:12px 20px; font-size:14px; font-weight:700; cursor:pointer; display:flex; align-items:center; gap:8px; white-space:nowrap; }
    .send-btn:disabled { opacity:0.4; cursor:not-allowed; }
  </style>
</head>
<body>

<header>
  <div class="logo"><span class="logo-text">MÓVIL SHOP <span>RD</span></span></div>
  <button class="cart-btn">
    🛒 Pedido <span class="cart-count" id="cartCount">0</span>
  </button>
</header>

<div class="hero">
  <div class="hero-tag">⚡ Inventario actualizado</div>
  <h1>Catálogo de<br/><span>Celulares</span></h1>
  <p>Selecciona equipos y envía tu pedido por WhatsApp</p>
  <div class="stock-badge"><span class="dot"></span> Stock disponible ahora</div>
</div>

<div class="filtros-wrapper">
  <div class="filtros" id="filtros"></div>
</div>

<div class="catalog-wrapper" id="catalogWrapper"></div>

<div class="footer-bar">
  <div class="footer-info">
    <span class="footer-label">Total de tu pedido</span>
    <span class="footer-total" id="totalDisplay">RD$0</span>
    <span class="empty-hint" id="emptyHint">Selecciona equipos arriba ↑</span>
  </div>
  <button class="send-btn" id="sendBtn" onclick="enviarPedido()" disabled>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    Enviar pedido
  </button>
</div>

<script>
  const WHATSAPP = "18492509710";
  const marcas = [

    { nombre: "Motorola", productos: [
      { id:40, nombre:"Motorola G06",          storage:"128GB+12GB", precio:6500,  extra:"" },
      { id:41, nombre:"Motorola G06",          storage:"256GB+12GB", precio:7200,  extra:"" },
